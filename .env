# ── Database ─────────────────────────────────────────────────────
DB_USER=bizadmin
DB_PASSWORD=bizpassword123
DB_NAME=bizanalysis

# ── App ───────────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-this-before-production

# ── ML Settings ───────────────────────────────────────────────────
# Path inside the container where trained models are saved as .pkl files
MODEL_DIR=/app/data/models

# Minimum training samples before a model can be used for prediction
MIN_TRAINING_SAMPLES=10